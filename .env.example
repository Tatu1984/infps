# PayPal Client ID for the JS SDK (browser-side, public).
# - Sandbox: https://developer.paypal.com/dashboard/applications/sandbox
# - Live:    https://developer.paypal.com/dashboard/applications/live
# Leaving this unset falls back to "test" mode (PayPal sandbox shim).
VITE_PAYPAL_CLIENT_ID=

# Calendly scheduling URL for /payment (browser-side, public).
# Create an event type for "1-Hour Consultation" at https://calendly.com and
# paste its public URL here, e.g. https://calendly.com/your-handle/consultation-1hr
VITE_CALENDLY_URL=

# Comma-separated list of IPs that always see the Pay Now (bank transfer) button,
# in addition to visitors detected as US (US) or UK (GB).
# Entries ending with "*" do a prefix match — useful for IPv6, where the /64
# prefix is stable per customer but the last 64 bits rotate.
# Examples:
#   VITE_PAYNOW_ALLOWED_IPS=203.0.113.5
#   VITE_PAYNOW_ALLOWED_IPS=2409:40e0:11dd:49d8:*
#   VITE_PAYNOW_ALLOWED_IPS=203.0.113.5,198.51.100.0/*
# Find your current IP at https://ipapi.co/json/  (the "ip" field) or on /payment.
VITE_PAYNOW_ALLOWED_IPS=

# Server-side (Vercel function) variables — DO NOT prefix with VITE_.
# Resend API key for sending invoice emails. Sign up at https://resend.com and create an API key.
RESEND_API_KEY=

# Address that invoices are sent FROM. Must be a verified Resend sender / domain.
# Falls back to Resend's "onboarding@resend.dev" if unset (works for testing only).
INVOICE_FROM_EMAIL="Infinititech Partners <billing@infinititechpartners.com>"

# Internal address that gets BCC'd on every invoice.
INVOICE_BCC_EMAIL=saddygrouppie@gmail.com

# Optional: PayPal server-side credentials for verifying captured orders before invoicing.
# If both are set, the function calls PayPal Orders API to confirm the order is COMPLETED
# and the amount matches before sending the invoice. Leave unset to skip verification.
# PAYPAL_ENV: "live" (default) or "sandbox".
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=live
